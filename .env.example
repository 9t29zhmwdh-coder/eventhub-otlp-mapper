# Azure EventHub
EVENTHUB_CONNECTION_STRING=Endpoint=sb://namespace.servicebus.windows.net/;SharedAccessKeyName=Listen;SharedAccessKey=YOUR_KEY
EVENTHUB_NAME=your-eventhub-name
EVENTHUB_CONSUMER_GROUP=$Default

# OpenTelemetry OTLP
OTLP_ENDPOINT=https://your-otlp-endpoint:4317
OTLP_API_KEY=your-api-key

# Azure Monitor / Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://...

# Mapping config path (optional, defaults to config/mapping.yaml)
MAPPING_CONFIG=config/mapping.yaml
